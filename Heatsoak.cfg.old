# ---------------------------------------------------------------------------
# PWM Heat Soak Monitor v0.65
# Author: Linearburn
#
# Purpose:
# Estimate thermal equilibrium using heater bed PWM duty cycle rather than
# a fixed soak timer.
#
# Theory:
# As the printer frame, bed, and surrounding components absorb heat, the
# bed heater must provide additional energy to maintain temperature.
# Once the system approaches thermal equilibrium, heater power stabilizes
# and the average PWM duty cycle decreases.
#
# Implementation:
# - PWM sample interval is configurable with variable_sample_time.
# - Timeout is configurable with variable_max_checks.
# - A linear PWM estimate contributes 0-50% progress.
# - A stability check contributes the remaining 50%.
# - Stability increases by 1 on a valid sample.
# - Stability decreases by 1 on an invalid sample.
# - Stability is clamped between 0 and 5.
# - Progress is monotonic and will never decrease.
#
# Stability Criteria:
# PWM < variable_done_pwm
# PWM delta from previous sample < 0.05
#
# Completion Criteria:
# Stability reaches 5/5.
#
# Failure Criteria:
# variable_max_checks samples without completion.
# Default: 60 samples x 20 seconds = 20 minute timeout.
#
# # Tunables:
# variable_bed_temp     = Bed test temperature.
# variable_hotend_temp  = Hotend test temperature.
# variable_done_pwm     = PWM threshold used for stability detection.
# variable_sample_time  = Sampling interval in seconds.
# variable_max_checks   = Maximum number of samples before timeout.
#
# Internal Constants:
# high_pwm             = 0% progress reference point (currently fixed at 0.80).
# stability_delta      = Maximum allowed PWM change between samples (currently 0.05).
#
# Runtime Setters:
# SET_PWM_SOAK_TEMPS BED=80 HOTEND=150
# SET_PWM_SOAK_THRESHOLD PWM=0.20
# SET_PWM_SOAK_TIMEOUT INTERVAL=20 CHECKS=60
#
# Notes:
# This is intended as a proof-of-concept and should not be considered a
# scientifically accurate measurement of thermal equilibrium. The goal is
# to provide a practical adaptive alternative to fixed-duration heat soak
# timers.
# ---------------------------------------------------------------------------


[gcode_macro PWM_SOAK_VARS]
variable_last_pwm: 1.0
variable_stable_count: 0
variable_last_percent: 0
variable_elapsed_checks: 0
variable_bed_temp: 80
variable_hotend_temp: 150
variable_done_pwm: 0.20
variable_sample_time: 20
variable_max_checks: 60
gcode:

[gcode_macro TEST_PRINT_START_PWM_SOAK]
description: Start PWM based heat soak test
gcode:
    {% set vars = printer["gcode_macro PWM_SOAK_VARS"] %}

    SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=last_pwm VALUE=1.0
    SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=stable_count VALUE=0
    SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=last_percent VALUE=0
    SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=elapsed_checks VALUE=0

    G28
    G0 X175 Y175 Z10 F9000

    M140 S{vars.bed_temp}
    M104 S{vars.hotend_temp}

    M190 S{vars.bed_temp}
    M109 S{vars.hotend_temp}

    RESPOND TYPE=COMMAND MSG="Starting PWM heat soak monitor"
    UPDATE_DELAYED_GCODE ID=PWM_SOAK_TEST DURATION={vars.sample_time}

[gcode_macro SET_PWM_SOAK_TEMPS]
description: Set soak test temperatures
gcode:
    {% if params.BED is defined %}
        SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=bed_temp VALUE={params.BED}
    {% endif %}
    {% if params.HOTEND is defined %}
        SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=hotend_temp VALUE={params.HOTEND}
    {% endif %}

[gcode_macro SET_PWM_SOAK_THRESHOLD]
description: Set PWM completion threshold
gcode:
    {% if params.PWM is defined %}
        SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=done_pwm VALUE={params.PWM}
        RESPOND TYPE=COMMAND MSG="PWM soak threshold set to {params.PWM}"
    {% endif %}

[gcode_macro SET_PWM_SOAK_TIMEOUT]
description: Set sample interval and max checks
gcode:
    {% if params.INTERVAL is defined %}
        SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=sample_time VALUE={params.INTERVAL}
    {% endif %}
    {% if params.CHECKS is defined %}
        SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=max_checks VALUE={params.CHECKS}
    {% endif %}
    RESPOND TYPE=COMMAND MSG="PWM soak timeout settings updated"

[gcode_macro STOP_PWM_SOAK_TEST]
description: Stop PWM heat soak test
gcode:
    UPDATE_DELAYED_GCODE ID=PWM_SOAK_TEST DURATION=0
    RESPOND TYPE=COMMAND MSG="PWM monitor stopped"

[delayed_gcode PWM_SOAK_TEST]
gcode:
    {% set vars = printer["gcode_macro PWM_SOAK_VARS"] %}
    {% set pwm = printer.heater_bed.power|float %}
    {% set last = vars.last_pwm|float %}
    {% set stable = vars.stable_count|int %}
    {% set last_percent = vars.last_percent|int %}
    {% set elapsed = vars.elapsed_checks|int + 1 %}
    {% set diff = (pwm - last)|abs %}

    {% set sample_time = vars.sample_time|int %}
    {% set max_checks = vars.max_checks|int %}
    {% set high_pwm = 0.80 %}
    {% set done_pwm = vars.done_pwm|float %}

    SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=elapsed_checks VALUE={elapsed}

    {% if elapsed >= max_checks %}
        RESPOND TYPE=error MSG="HEAT SOAK ABORTED: exceeded configured timeout without reaching stability"
        UPDATE_DELAYED_GCODE ID=PWM_SOAK_TEST DURATION=0
    {% else %}
        {% if pwm >= high_pwm %}
            {% set pwm_percent = 0 %}
        {% elif pwm <= done_pwm %}
            {% set pwm_percent = 50 %}
        {% else %}
            {% set pwm_percent = ((((high_pwm - pwm) / (high_pwm - done_pwm)) * 50)|int) %}
        {% endif %}

        {% if pwm < done_pwm and diff < 0.05 %}
            {% set new_stable = stable + 1 %}
        {% else %}
            {% set new_stable = stable - 1 %}
        {% endif %}

        {% if new_stable < 0 %}
            {% set new_stable = 0 %}
        {% endif %}

        {% if new_stable > 5 %}
            {% set new_stable = 5 %}
        {% endif %}

        {% if new_stable > 0 %}
            {% set raw_percent = 50 + (new_stable * 10) %}
        {% else %}
            {% set raw_percent = pwm_percent %}
        {% endif %}

        {% if raw_percent < last_percent %}
            {% set soak_percent = last_percent %}
        {% else %}
            {% set soak_percent = raw_percent %}
        {% endif %}

        RESPOND TYPE=COMMAND MSG="Heat soak estimated {soak_percent}% | Stability {new_stable}/5"

        SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=stable_count VALUE={new_stable}
        SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=last_pwm VALUE={pwm}
        SET_GCODE_VARIABLE MACRO=PWM_SOAK_VARS VARIABLE=last_percent VALUE={soak_percent}

        {% if new_stable >= 5 %}
            RESPOND TYPE=COMMAND MSG="HEAT SOAK COMPLETE"
            UPDATE_DELAYED_GCODE ID=PWM_SOAK_TEST DURATION=0
        {% else %}
            UPDATE_DELAYED_GCODE ID=PWM_SOAK_TEST DURATION={sample_time}
        {% endif %}
    {% endif %}
